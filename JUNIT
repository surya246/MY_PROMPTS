#!/bin/bash

# Step 1: Run JaCoCo to get current coverage
echo "Running coverage report..."
mvn test jacoco:report -q --no-transfer-progress 2>/dev/null

# Step 2: Parse JaCoCo XML to find classes < 90% line coverage
python3 - <<'EOF' > /tmp/todo.txt
import xml.etree.ElementTree as ET

tree = ET.parse('target/site/jacoco/jacoco.xml')
root = tree.getroot()

for pkg in root.findall('package'):
    for cls in pkg.findall('class'):
        name = cls.get('name')  # com/dbs/epms/service/FooService
        
        # Skip configs, exceptions, constants
        skip = ['Application','Config','Exception','Constants','Enum']
        if any(s in name for s in skip):
            continue
        
        lines = cls.find(".//counter[@type='LINE']")
        if lines is None:
            continue
            
        missed = int(lines.get('missed', 0))
        covered = int(lines.get('covered', 0))
        total = missed + covered
        
        if total == 0:
            continue
            
        pct = (covered / total) * 100
        
        if pct < 90:
            # Convert to file path
            src = f"src/main/java/{name}.java"
            test = f"src/test/java/{name}Test.java"
            print(f"{src}|{test}|{int(pct)}")
EOF

echo "Classes below 90% coverage:"
cat /tmp/todo.txt

# Step 3: Also extract which specific lines are uncovered per class
python3 - <<'EOF' > /tmp/uncovered-lines.txt
import xml.etree.ElementTree as ET

tree = ET.parse('target/site/jacoco/jacoco.xml')
root = tree.getroot()

for pkg in root.findall('package'):
    for cls in pkg.findall('class'):
        name = cls.get('name')
        for line in cls.findall('line'):
            if line.get('mi', '0') != '0':  # missed instructions > 0
                print(f"{name}:{line.get('nr')}")
EOF

# Step 4: Hand Claude exact targets — no discovery needed
CLASS_LIST=$(awk -F'|' '{print $1" ("$3"% covered)"}' /tmp/todo.txt | tr '\n' '\n')
LINE_HINTS=$(cat /tmp/uncovered-lines.txt)

claude -p "
Existing coverage is already 40%+. DO NOT regenerate passing tests.

Target only these classes (all below 90% line coverage):
$CLASS_LIST

Uncovered lines by class:
$LINE_HINTS

Instructions:
- Read existing test file first if it exists
- Add ONLY missing test cases that cover the uncovered lines above
- Never delete or modify existing tests
- Use @Mock + @InjectMocks, no @SpringBootTest, Jakarta imports
- No questions, no explanations, write and move to next class

After all done:
  mvn test jacoco:report -q --no-transfer-progress
  python3 -c \"
